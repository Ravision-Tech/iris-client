{
  "endOfLine": "lf",
  "importOrder": ["<THIRD_PARTY_MODULES>", "", "^[./]"],
  "importOrderParserPlugins": ["typescript", "decorators-legacy"],
  "plugins": ["@ianvs/prettier-plugin-sort-imports", "prettier-plugin-sort-json"],
  "printWidth": 120,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "es5"
}
